`timescale 1ns/1ps

module clock_divider(
    input wire clock, 
    input wire reset, 
    output reg mod_clock 
);

reg[1:0] count;

always @(posedge clock, posedge reset) begin 
    if(reset) begin
        count <= 2'b0;
        mod_clock <= 1'b0;
    end else if(count == 2'b01) begin
        mod_clock <= ~mod_clock;
        count <= 2'b0;
    end else begin
        count <= count + 1;
    end
end

endmodule
